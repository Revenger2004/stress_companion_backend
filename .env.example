# ==========================================
# Stress Companion Backend - Environment Variables
# ==========================================

# 1. Environment State
# Set to 'development' for local testing, or 'production' when deploying.
ENVIRONMENT=development

# 2. CORS Allowed Origins
# A comma-separated list of URLs that are allowed to talk to this backend.
# Do NOT put spaces around the commas or trailing slashes at the end of the URLs.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://stresscompanion.vercel.app

# 3. Google Gemini API Key
# Required for the AI chat companion to function.
# Get your free API key here: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# 4. Project Configuration (Optional)
PROJECT_NAME="Stress Companion API"